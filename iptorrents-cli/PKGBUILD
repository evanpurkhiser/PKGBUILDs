# Maintainer: Evan Purkhiser <evanpurkhiser@gmail.com>

pkgname=iptorrents-cli
pkgver=0.1.1
pkgrel=1
pkgdesc="CLI for searching and downloading torrents from IPTorrents"
arch=('x86_64' 'aarch64')
url="https://github.com/evanpurkhiser/iptorrents-cli"
license=('MIT')
depends=('glibc' 'gcc-libs')
makedepends=('cargo')
options=('!lto')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/evanpurkhiser/iptorrents-cli/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('e42035d6be3092f4c8a3f82f14ffaaa0cc46a3647b6d01688bee7ef74a92fb3f')

build() {
	cd "${srcdir}/${pkgname}-${pkgver}"
	cargo build --release --locked
}

package() {
	cd "${srcdir}/${pkgname}-${pkgver}"

	install -Dm755 target/release/ipt "${pkgdir}/usr/bin/ipt"
	install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
