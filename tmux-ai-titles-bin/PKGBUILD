# Maintainer: Evan Purkhiser <evanpurkhiser@gmail.com>

pkgname=tmux-ai-titles-bin
pkgver=0.0.1
pkgrel=1
pkgdesc="AI-powered title generation for tmux panes and windows (prebuilt binary)"
arch=('x86_64' 'aarch64')
url="https://github.com/evanpurkhiser/tmux-ai-titles"
license=('MIT')
depends=('glibc' 'gcc-libs')
provides=("tmux-ai-titles=${pkgver}")
conflicts=('tmux-ai-titles')
source=("LICENSE::https://raw.githubusercontent.com/evanpurkhiser/tmux-ai-titles/v${pkgver}/LICENSE")
source_x86_64=("tmux-ai-titles-linux-amd64::https://github.com/evanpurkhiser/tmux-ai-titles/releases/download/v${pkgver}/tmux-ai-titles-linux-amd64")
source_aarch64=("tmux-ai-titles-linux-arm64::https://github.com/evanpurkhiser/tmux-ai-titles/releases/download/v${pkgver}/tmux-ai-titles-linux-arm64")
sha256sums=('9542153dceaec06371699a2066fe36eaf721da9c6f4d34d54580fabb845088d6')
sha256sums_x86_64=('9c9eea57e0405abf99ade0fa0e5ea48d15bb431393733c769357a09625a80c25')
sha256sums_aarch64=('ff6df90a639e8273f20ba4700006d93310e3622c46f7d217c777b8fde5db6190')

package() {
	local _bin
	case "${CARCH}" in
		x86_64) _bin="tmux-ai-titles-linux-amd64" ;;
		aarch64) _bin="tmux-ai-titles-linux-arm64" ;;
		*) printf 'Unsupported architecture: %s\n' "${CARCH}" >&2; return 1 ;;
	esac

	install -Dm755 "${srcdir}/${_bin}" "${pkgdir}/usr/bin/tmux-ai-titles"
	install -Dm644 "${srcdir}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
